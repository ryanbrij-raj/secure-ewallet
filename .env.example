# ============================================================
#  Secure E-Wallet — Environment Variables
#
#  Copy this file to `.env` and fill in real values.
#  `.env` is git-ignored — never commit real secrets.
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ewallet_db
DB_USERNAME=ewallet_user
DB_PASSWORD=replace-with-a-strong-password

# ── JWT signing secret ──────────────────────────────────────
# Must be a high-entropy random string, at least 32 bytes (256 bits).
# Generate one with:
#   openssl rand -base64 48
JWT_SECRET=replace-with-a-generated-256-bit-secret

# ── PII encryption key (AES-256) ────────────────────────────
# Must be exactly 32 bytes, hex-encoded (64 hex characters).
# Generate one with:
#   openssl rand -hex 32
ENCRYPTION_KEY=replace-with-a-generated-32-byte-hex-key
